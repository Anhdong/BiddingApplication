<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" prefHeight="280.0" prefWidth="210.0" spacing="4.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <ImageView fitHeight="140.0" fitWidth="140.0" nodeOrientation="INHERIT" pickOnBounds="true" styleClass="elevated-4">
         <image>
            <Image url="@../../assets/default-items.png" />
         </image></ImageView>
      <Label maxWidth="1.7976931348623157E308" styleClass="title-3" text="Name" />
      <Label maxWidth="1.7976931348623157E308" text="hh:mm - dd/mm/yyyy">
         <styleClass>
            <String fx:value="text-muted" />
            <String fx:value="text-caption" />
         </styleClass>
      </Label>
      <HBox alignment="CENTER" maxHeight="-Infinity" maxWidth="1.7976931348623157E308" prefHeight="100.0" prefWidth="200.0">
         <children>
            <Label maxWidth="1.7976931348623157E308" text="\$100000" HBox.hgrow="NEVER">
               <styleClass>
                  <String fx:value="success" />
                  <String fx:value="title-4" />
               </styleClass>
            </Label>
            <Region maxWidth="1.7976931348623157E308" HBox.hgrow="ALWAYS" />
            <Button alignment="CENTER" mnemonicParsing="false" text="Add">
               <styleClass>
                  <String fx:value="accent" />
                  <String fx:value="bold" />
               </styleClass>
            </Button>
         </children>
      </HBox>
   </children>
   <padding>
      <Insets bottom="18.0" left="28.0" right="28.0" top="18.0" />
   </padding>
   <styleClass>
      <String fx:value="rounded-card" />
      <String fx:value="interactive-card" />
   </styleClass>
</VBox>
