<StackPane maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minHeight="-Infinity" minWidth="-Infinity" prefHeight="800.0" prefWidth="1080.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.uet.BiddingApplication.Controller.AdminController.AdminUsersController">
   <children>
      <TableView fx:id="table" prefHeight="800.0" prefWidth="1080.0" styleClass="bg-default">
