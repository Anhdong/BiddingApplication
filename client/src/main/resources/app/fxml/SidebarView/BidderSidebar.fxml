<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_CENTER" maxHeight="1.7976931348623157E308" maxWidth="200.0" prefHeight="800.0" prefWidth="200.0" styleClass="bg-neutral-emphasis-plus" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <HBox alignment="CENTER_RIGHT" prefHeight="100.0" prefWidth="200.0">
         <children>
            <ImageView fitHeight="64.0" fitWidth="64.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@../../assets/profile.png" />
               </image>
            </ImageView>
         </children>
         <VBox.margin>
            <Insets />
         </VBox.margin>
         <padding>
            <Insets left="10.0" right="10.0" />
         </padding>
      </HBox>
      <Separator>
         <VBox.margin>
            <Insets bottom="10.0" />
         </VBox.margin>
      </Separator>
      <ToggleButton maxHeight="80.0" maxWidth="1.7976931348623157E308" mnemonicParsing="false" prefHeight="80.0" selected="true" text="Browse">
         <toggleGroup>
            <ToggleGroup fx:id="Navigation" />
         </toggleGroup>
         <styleClass>
            <String fx:value="flat" />
            <String fx:value="title-3" />
         </styleClass>
      </ToggleButton>
      <ToggleButton maxHeight="80.0" maxWidth="1.7976931348623157E308" mnemonicParsing="false" prefHeight="80.0" text="Watchlist" toggleGroup="$Navigation">
         <styleClass>
            <String fx:value="flat" />
            <String fx:value="title-3" />
         </styleClass>
      </ToggleButton>
      <ToggleButton maxHeight="80.0" maxWidth="1.7976931348623157E308" mnemonicParsing="false" prefHeight="80.0" text="History" toggleGroup="$Navigation">
         <styleClass>
            <String fx:value="flat" />
            <String fx:value="title-3" />
         </styleClass>
      </ToggleButton>
   </children>
</VBox>
