<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.TilePane?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" prefHeight="800.0" prefWidth="1080.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.uet.BiddingApplication.Controller.SellerController.SellerItemsController">
   <center>
      <StackPane BorderPane.alignment="CENTER">
         <children>
            <ScrollPane fitToWidth="true" hbarPolicy="NEVER">
               <content>
                  <TilePane fx:id="itemContainer" hgap="45.0" vgap="24.0">
                     <padding>
                        <Insets left="45.0" right="45.0" top="24.0" />
                     </padding>
                  </TilePane>
               </content>
            </ScrollPane>
            <Button fx:id="btnAdd" defaultButton="true" mnemonicParsing="false" onAction="#switchToAddItem" styleClass="title-1" text="ADD" StackPane.alignment="BOTTOM_RIGHT">
               <graphic>
                  <FontIcon iconLiteral="mdi2p-plus" styleClass="large-icon" />
               </graphic>
               <StackPane.margin>
                  <Insets bottom="24.0" right="24.0" />
               </StackPane.margin>
            </Button>
         </children>
      </StackPane>
   </center>
   <top>
      <HBox alignment="CENTER" maxWidth="500.0" spacing="10.0" BorderPane.alignment="CENTER">
         <children>
            <FontIcon iconLiteral="mdi2m-magnify" styleClass="large-icon" />
            <TextField fx:id="searchField" maxWidth="-Infinity" prefHeight="50.0" prefWidth="500.0" promptText="Search here..." style="-fx-background-color: transparent;">
               <HBox.margin>
                  <Insets />
               </HBox.margin></TextField>
         </children>
         <padding>
            <Insets bottom="8.0" left="24.0" right="24.0" top="8.0" />
         </padding>
         <BorderPane.margin>
            <Insets bottom="24.0" top="24.0" />
         </BorderPane.margin>
         <styleClass>
            <String fx:value="border-subtle" />
            <String fx:value="rounded" />
            <String fx:value="title-1" />
         </styleClass>
      </HBox>
   </top>
</BorderPane>
