<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.TilePane?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" prefHeight="800.0" prefWidth="1080.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.uet.BiddingApplication.Controller.BidderController.BidderBrowseController">
   <center>
      <ScrollPane fitToWidth="true" hbarPolicy="NEVER" BorderPane.alignment="CENTER">
         <content>
            <TilePane fx:id="itemContainer" hgap="45.0" vgap="24.0">
               <padding>
                  <Insets left="45.0" right="45.0" top="24.0" />
               </padding></TilePane>
         </content>
      </ScrollPane>
   </center>
   <top>
      <HBox alignment="CENTER" maxWidth="500.0" spacing="10.0" BorderPane.alignment="CENTER">
         <children>
            <Label>
               <graphic>
                  <FontIcon iconLiteral="mdi2m-magnify" styleClass="large-icon" />
               </graphic>
            </Label>
            <TextField fx:id="searchField" maxWidth="-Infinity" onAction="#onSearchEnter" prefHeight="50.0" prefWidth="500.0" promptText="Search here..." style="-fx-background-color: transparent;">
               <HBox.margin>
                  <Insets />
               </HBox.margin></TextField>
         </children>
         <padding>
            <Insets bottom="8.0" left="24.0" right="24.0" top="8.0" />
         </padding>
         <BorderPane.margin>
            <Insets bottom="24.0" top="24.0" />
         </BorderPane.margin>
         <styleClass>
            <String fx:value="border-subtle" />
            <String fx:value="rounded" />
            <String fx:value="title-1" />
         </styleClass>
      </HBox>
   </top>
</BorderPane>
