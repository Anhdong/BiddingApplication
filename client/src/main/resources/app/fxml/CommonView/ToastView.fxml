<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<HBox fx:id="rootBox" alignment="CENTER_LEFT" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="80.0" prefWidth="350.0" spacing="15.0" styleClass="bg-default" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.uet.BiddingApplication.Controller.CommonController.ToastController">
   <children>
      <FontIcon fx:id="icon" iconLiteral="mdi2i-information" styleClass="large-icon" />
      <VBox alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
         <children>
            <Label fx:id="lblTitle" text="Title">
               <styleClass>
                  <String fx:value="title-3" />
                  <String fx:value="bold" />
               </styleClass>
            </Label>
            <Label fx:id="lblContent" text="Notification content goes here" wrapText="true">
               <styleClass>
                  <String fx:value="text-subtle" />
               </styleClass>
            </Label>
         </children>
      </VBox>
   </children>
   <padding>
      <Insets bottom="15.0" left="20.0" right="20.0" top="15.0" />
   </padding>
</HBox>
